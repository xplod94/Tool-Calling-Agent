{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "🚀 Backend: Dev Server (tsx watch)",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "npm",
            "runtimeArgs": [
                "run",
                "dev"
            ],
            "cwd": "${workspaceFolder}/backend",
            "env": {
                "NODE_ENV": "development"
            },
            "sourceMaps": true,
            "resolveSourceMapLocations": [
                "${workspaceFolder}/backend/**",
                "!**/node_modules/**"
            ],
            "skipFiles": [
                "<node_internals>/**",
                "**/node_modules/**"
            ],
            "console": "integratedTerminal"
        },
        {
            "name": "🔍 Backend: Debug Current File",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/tsx",
            "args": [
                "${file}"
            ],
            "cwd": "${workspaceFolder}/backend",
            "env": {
                "NODE_ENV": "development"
            },
            "sourceMaps": true,
            "resolveSourceMapLocations": [
                "${workspaceFolder}/backend/**",
                "!**/node_modules/**"
            ],
            "skipFiles": [
                "<node_internals>/**",
                "**/node_modules/**"
            ]
        },
        {
            "name": "🏭 Backend: Production Build + Run",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}/backend/dist/index.js",
            "cwd": "${workspaceFolder}/backend",
            "env": {
                "NODE_ENV": "production"
            },
            "preLaunchTask": "backend: build",
            "skipFiles": [
                "<node_internals>/**",
                "**/node_modules/**"
            ]
        },
        {
            "name": "🌐 Client: ng serve",
            "type": "chrome",
            "request": "launch",
            "cwd": "${workspaceFolder}/client",
            "preLaunchTask": "client: start",
            "url": "http://localhost:4200/"
        },
        {
            "name": "🤖 Client: ng test",
            "type": "chrome",
            "request": "launch",
            "cwd": "${workspaceFolder}/client",
            "preLaunchTask": "client: test",
            "url": "http://localhost:9876/debug.html"
        }
    ]
}